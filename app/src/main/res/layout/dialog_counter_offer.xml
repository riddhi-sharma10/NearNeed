<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/bg_bottom_sheet_modal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- District Handle -->
        <View
            android:layout_width="44dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:background="@color/border_standard" />

        <!-- Title -->
        <TextView
            style="@style/AppHeading"
            android:id="@+id/tvCounterTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Counter Offer"
            android:textColor="@color/text_header"
            android:textSize="22sp" />

        <!-- Original Price Info -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_alert_yellow"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/icPrice"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentStart="true"
                android:src="@drawable/ic_cash_icon"
                app:tint="@color/brand_warning_solid" />

            <TextView
                style="@style/AppHeading"
                android:id="@+id/tvOriginalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/icPrice"
                android:layout_marginStart="12dp"
                android:text="Original offer: ₹300"
                android:textColor="@color/brand_warning_text"
                android:textSize="14sp" />
        </RelativeLayout>

        <!-- Your Counter Price Label -->
        <TextView
            style="@style/AppHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Your Counter Price"
            android:textColor="@color/text_header"
            android:textSize="14sp" />

        <!-- Price Input Field -->
        <EditText
            style="@style/AppFormText"
            android:id="@+id/etCounterPrice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_outline"
            android:backgroundTint="@color/surface_background"
            android:hint="Enter your offer price (e.g., 280)"
            android:inputType="number"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="14sp"
            android:textColor="@color/text_header"
            android:textColorHint="@color/text_muted" />

        <!-- Info Text -->
        <TextView
            style="@style/AppDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="You can offer a lower or higher price. The applicant will receive a notification about your counter offer."
            android:textColor="@color/text_subheadline"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendCounterOffer"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Send Counter Offer"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="10dp"
                android:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelCounterOffer"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Cancel"
                android:textColor="@color/text_subheadline"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="@color/divider_soft"
                app:cornerRadius="10dp"
                android:elevation="0dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
