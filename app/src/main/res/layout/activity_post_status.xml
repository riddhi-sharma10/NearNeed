<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background">


    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════ TOP APP BAR ══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:elevation="4dp"
                android:background="@color/white"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Back Button -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow"
                    android:padding="8dp"
                    app:tint="@color/text_header" />

                <!-- Title -->
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Update Post"
                    android:textColor="@color/text_header"
                    android:textSize="18sp"
                    android:layout_marginStart="16dp" />
            </LinearLayout>

            <!-- ══════════ CONTENT ══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <!-- ══════════ CONFIRMATION SECTION ══════════ -->
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Is the task complete?"
                    android:textColor="@color/text_header"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp" />

                <!-- Confirmation Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Confirming completion will notify the community and update the post status."
                            android:textColor="@color/text_subheadline"
                            android:textSize="14sp"
                            android:lineSpacingExtra="2dp"
                            android:layout_marginBottom="16dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnYesHelped"
                            style="@style/AppHeading"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Yes, task completed"
                            android:textColor="@color/white"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            app:backgroundTint="@color/brand_primary"
                            app:cornerRadius="10dp"
                            android:elevation="0dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNotYet"
                            style="@style/AppHeading"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="8dp"
                            android:text="Not yet"
                            android:textColor="@color/text_subheadline"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            app:backgroundTint="@color/divider_soft"
                            app:cornerRadius="10dp"
                            android:elevation="0dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ══════════ VOLUNTEERS SECTION ══════════ -->
                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Which volunteers have completed?"
                    android:textColor="@color/text_header"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp" />

                <!-- Card 1: Michael Chen -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:id="@+id/rowMichael"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:backgroundTint="@color/brand_info_bg"
                            android:src="@drawable/bg_image_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Michael Chen"
                                android:textColor="@color/text_header"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Volunteered 2 days ago"
                                android:textColor="@color/text_subheadline"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Empty Checkbox -->
                        <ImageView
                            android:id="@+id/cbMichael"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_card_outline" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 2: Elena Rodriguez (Checked) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:id="@+id/rowElena"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:backgroundTint="@color/brand_warning_bg_alt"
                            android:src="@drawable/bg_image_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Elena Rodriguez"
                                android:textColor="@color/text_header"
                                android:textSize="14sp" />

                            <TextView
                                style="@style/AppDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Completed yesterday"
                                android:textColor="@color/text_subheadline"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Checked Checkbox -->
                        <ImageView
                            android:id="@+id/cbElena"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:backgroundTint="@color/brand_error_solid"
                            android:padding="4dp"
                            android:src="@drawable/ic_check_solid_white" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 3: David Wilson -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:id="@+id/rowDavid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:backgroundTint="@color/brand_warning_bg_alt"
                            android:src="@drawable/bg_image_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="David Wilson"
                                android:textColor="@color/text_header"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Pending response"
                                android:textColor="@color/text_subheadline"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Empty Checkbox -->
                        <ImageView
                            android:id="@+id/cbDavid"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_card_outline" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Bottom Action Button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:paddingTop="16dp"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFinalUpdateStatus"
                        style="@style/AppHeading"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Confirm Changes"
                        android:textColor="@color/white"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        app:backgroundTint="@color/brand_primary"
                        app:cornerRadius="10dp"
                        android:elevation="0dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Helper -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>










