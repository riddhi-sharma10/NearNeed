<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background_clean"
    tools:ignore="HardcodedText,ContentDescription">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- App Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow" />

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Update Post"
                    android:textColor="@color/text_header"
                    android:textSize="18sp" />
            </RelativeLayout>

            <!-- Status Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginTop="32dp">

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Is the task complete?"
                    android:textColor="@color/text_header"
                    android:textSize="22sp"
                    android:textAlignment="center"
                    android:layout_marginBottom="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnYesHelped"
                    style="@style/AppHeading"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Yes, task completed"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/brand_primary"
                    app:cornerRadius="10dp"
                    android:elevation="0dp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNotYet"
                    style="@style/AppHeading"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Not yet"
                    android:textColor="@color/text_subheadline"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/divider_soft"
                    app:cornerRadius="10dp"
                    android:elevation="0dp" />

                <TextView
                    style="@style/AppDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Confirming completion will notify volunteers and update the post status."
                    android:textColor="@color/text_subheadline"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginTop="16dp" />
            </LinearLayout>

            <!-- Volunteers Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginTop="48dp">

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Which volunteers helped?"
                    android:textColor="@color/text_header"
                    android:textSize="22sp"
                    android:textAlignment="center"
                    android:layout_marginBottom="24dp" />

                <!-- Card 1: Michael Chen -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:id="@+id/rowMichael"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:backgroundTint="@color/brand_info_bg"
                            android:src="@drawable/bg_image_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Michael Chen"
                                android:textColor="@color/text_header"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Volunteered 2 days ago"
                                android:textColor="@color/text_subheadline"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Unchecked -->
                        <ImageView
                            android:id="@+id/cbMichael"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_card_outline" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 2: Elena Rodriguez -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:id="@+id/rowElena"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:backgroundTint="@color/brand_warning_bg_alt"
                            android:src="@drawable/bg_image_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Elena Rodriguez"
                                android:textColor="@color/text_header"
                                android:textSize="14sp" />

                            <TextView
                                style="@style/AppDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Completed yesterday"
                                android:textColor="@color/text_subheadline"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Checked -->
                        <ImageView
                            android:id="@+id/cbElena"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check_solid_white"
                            android:tint="@color/brand_primary" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 3: Sofia the Plumber -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:id="@+id/rowSofia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_solid_red"
                            android:backgroundTint="@color/brand_success_alt"
                            android:src="@drawable/bg_image_placeholder" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/AppHeading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sofia the Plumber"
                                android:textColor="@color/text_header"
                                android:textSize="14sp" />

                            <TextView
                                style="@style/AppDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Still in progress"
                                android:textColor="@color/text_subheadline"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Unchecked -->
                        <ImageView
                            android:id="@+id/cbSofia"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_card_outline" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>










