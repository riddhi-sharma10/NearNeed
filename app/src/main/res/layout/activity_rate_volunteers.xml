<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background_clean"
    tools:ignore="HardcodedText,ContentDescription">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- App Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow" />

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Rate Volunteer"
                    android:textColor="@color/text_header"
                    android:textSize="18sp" />
            </RelativeLayout>

            <!-- Avatar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_circle_solid_red"
                    android:backgroundTint="@color/brand_primary"
                    android:src="@drawable/bg_image_placeholder" />

                <!-- Badge -->
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignEnd="@+id/ivAvatar"
                    android:layout_alignBottom="@+id/ivAvatar"
                    android:layout_marginEnd="-6dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/bg_circle_solid_red"
                    android:backgroundTint="@color/brand_primary"
                    android:padding="6dp"
                    android:src="@drawable/ic_check_solid_white" />
                    
                <!-- Dummy view for alignment -->
                <View
                    android:id="@+id/ivAvatar"
                    android:layout_width="120dp"
                    android:layout_height="120dp" />
            </RelativeLayout>

            <!-- Name and prompt -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:id="@+id/tvApplicantName"
                android:text="Rahul S."
                android:textAlignment="center"
                android:textColor="@color/text_header"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                style="@style/AppDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="How was your experience?"
                android:textAlignment="center"
                android:textColor="@color/brand_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Stars -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center">

                <RatingBar
                    android:id="@+id/ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:rating="0"
                    android:stepSize="1"
                    android:isIndicator="false"
                    android:progressTint="@color/brand_primary"
                    android:progressBackgroundTint="@color/text_muted"
                    android:secondaryProgressTint="@color/brand_primary"
                    android:scaleX="1.5"
                    android:scaleY="1.5"
                    style="@style/Widget.AppCompat.RatingBar.Indicator" />
            </LinearLayout>

            <!-- Status Text -->
            <TextView
                android:id="@+id/tvRatingValue"
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:textColor="@color/brand_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Comment Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Additional Comments (Optional)"
                    android:textColor="@color/text_header"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/etReviewText"
                    style="@style/AppFormText"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_card_outline"
                    android:backgroundTint="@color/white"
                    android:gravity="top"
                    android:hint="Share your feedback..."
                    android:inputType="textMultiLine"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:textSize="15sp"
                    android:textColor="@color/text_header"
                    android:textColorHint="@color/text_muted" />
            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitRating"
                    style="@style/AppHeading"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Submit Rating"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/brand_primary"
                    app:cornerRadius="10dp"
                    android:elevation="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelRating"
                    style="@style/AppHeading"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="Cancel"
                    android:textColor="@color/text_subheadline"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/divider_soft"
                    app:cornerRadius="10dp"
                    android:elevation="0dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
