<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/bg_bottom_sheet_modal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- District Handle -->
        <View
            android:layout_width="44dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:background="@color/border_standard" />

        <!-- Avatar + Name + Rating Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <!-- Avatar -->
            <ImageView
                android:id="@+id/ivApplicantAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_light_blue"
                android:src="@drawable/bg_image_placeholder"
                android:scaleType="centerCrop" />

            <!-- Name + Rating -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/ivApplicantAvatar"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp"
                android:orientation="vertical">

                <TextView
                    style="@style/AppHeading"
                    android:id="@+id/tvApplicantName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Priya M."
                    android:textColor="@color/text_header"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_star_yellow" />

                    <TextView
                        style="@style/AppHeading"
                        android:id="@+id/tvApplicantRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="4.5"
                        android:textColor="@color/brand_warning_solid"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>

        <!-- Message Text -->
        <TextView
            style="@style/AppDescription"
            android:id="@+id/tvApplicantMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="I'm available this weekend and have 5 years of experience with tap installations and repairs."
            android:textColor="@color/text_subheadline"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="24dp" />

        <!-- Proposed Price Chip -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_alert_yellow"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/icPriceDetail"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentStart="true"
                android:src="@drawable/ic_cash_icon"
                app:tint="@color/brand_warning_solid" />

            <TextView
                style="@style/AppHeading"
                android:id="@+id/tvProposedPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/icPriceDetail"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:text="Proposed ₹250 (you posted ₹300)"
                android:textColor="@color/brand_warning_text"
                android:textSize="14sp" />
        </RelativeLayout>

        <!-- Action Buttons Row 1: Accept + Counter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAcceptApplicant"
                style="@style/AppHeading"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:layout_marginEnd="12dp"
                android:text="Accept ₹250"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="@color/brand_success_alt"
                app:cornerRadius="10dp"
                android:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCounterApplicant"
                style="@style/AppHeading"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="Counter"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="10dp"
                android:elevation="0dp" />
        </LinearLayout>

        <!-- Action Buttons Row 2: Decline + Chat -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeclineApplicant"
                style="@style/AppHeading"
                android:layout_width="0dp"
                android:layout_weight="0.65"
                android:layout_height="48dp"
                android:layout_marginEnd="12dp"
                android:text="Decline"
                android:textColor="@color/text_subheadline"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="@color/divider_soft"
                app:cornerRadius="10dp"
                android:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChatApplicant"
                android:layout_width="0dp"
                android:layout_weight="0.35"
                android:layout_height="48dp"
                app:icon="@drawable/ic_chat_outline"
                app:iconGravity="textStart"
                app:iconTint="@color/brand_primary"
                app:backgroundTint="@color/brand_primary_light"
                app:cornerRadius="10dp"
                android:elevation="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
