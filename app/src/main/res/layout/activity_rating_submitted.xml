<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background_clean"
    tools:ignore="HardcodedText,ContentDescription">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="120dp">

            <!-- App Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="✕"
                    android:textColor="@color/text_header"
                    android:textSize="24sp" />

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Rating Confirmation"
                    android:textColor="@color/text_header"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- Star Graphic -->
            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:layout_marginTop="80dp"
                android:background="@drawable/bg_circle_solid_red"
                android:backgroundTint="@color/brand_warning_bg_alt">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/star_on"
                    app:tint="@color/brand_warning_vibrant" />
            </FrameLayout>

            <!-- Texts -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Rating submitted."
                android:textAlignment="center"
                android:textColor="@color/text_header"
                android:textSize="22sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="Anjali M.'s Neighbour Score has been updated."
                android:textAlignment="center"
                android:textColor="@color/text_subheadline"
                android:textSize="14sp" />

            <!-- Info Pill -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_pill_pink_transparent"
                android:backgroundTint="@color/brand_error_bg_alt"
                android:paddingStart="20dp"
                android:paddingTop="12dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Waiting for Anjali M. to rate you."
                    android:textColor="@color/brand_error_vibrant"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Back to Feed Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackToFeed"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="48dp"
                android:layout_marginEnd="24dp"
                android:elevation="8dp"
                android:text="Back to Feed"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:backgroundTint="@color/brand_error_solid"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Universal Navigation System -->
    <include layout="@layout/layout_universal_navbar" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>









