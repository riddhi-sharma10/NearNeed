<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical|start"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back_arrow" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/txt_verify_your_number"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="@string/txt_verify_your_number_1"
            android:textColor="#101D33"
            android:textSize="26sp"
            android:letterSpacing="-0.02"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCodeSentTo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/txt_code_sent_to_91_xxxxx_xxxxx"
            android:textColor="#64748B"
            android:textSize="13sp" />

        <!-- 6 OTP Boxes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:weightSum="6">

            <EditText
                android:id="@+id/otpBox1"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/sel_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold" />
                
            <EditText
                android:id="@+id/otpBox2"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/sel_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/otpBox3"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/sel_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/otpBox4"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/sel_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/otpBox5"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/sel_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/otpBox6"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:background="@drawable/sel_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerify"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="@string/txt_verify"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#1D5EF3"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_forward_arrow"
            app:iconSize="14dp"
            app:iconGravity="textEnd"
            app:iconTint="#FFFFFF"
            android:elevation="6dp"
            android:outlineAmbientShadowColor="#1D5EF3"
            android:outlineSpotShadowColor="#1D5EF3" />

        <TextView
            android:id="@+id/btnResend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/txt_resend_code"
            android:textColor="#2563EB"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
